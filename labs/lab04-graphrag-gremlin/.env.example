# Azure Subscription and Resource Group
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
RESOURCE_GROUP_NAME=rg-graphrag-lab
AZURE_LOCATION=eastus

# Project Configuration
PROJECT_NAME=graphrag
ENVIRONMENT=dev

# Cosmos DB for Apache Gremlin
COSMOS_ACCOUNT_NAME=cosmos-graphrag-dev
COSMOS_DATABASE_NAME=graphrag-db
COSMOS_GRAPH_NAME=knowledge-graph
COSMOS_THROUGHPUT=400

# Azure AI Search
SEARCH_SERVICE_NAME=search-graphrag-dev
SEARCH_SKU=basic
SEARCH_INDEX_NAME=chunks-index

# Azure OpenAI
OPENAI_ACCOUNT_NAME=oai-graphrag-dev
OPENAI_SKU=S0
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_MODEL_VERSION=1

# Azure Storage
STORAGE_ACCOUNT_NAME=stgraphragdev
STORAGE_CONTAINER_NAME=documents

# Query Configuration
DEFAULT_TENANT=default
