# =============================================================================
# Azure AI Foundry Configuration
# =============================================================================

# Required: Your Azure AI Project endpoint from Microsoft Foundry
# Format: https://<account_name>.services.ai.azure.com/api/projects/<project_name>
# Find this in your Foundry project overview page
AZURE_AI_PROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project-name

# Optional: Specific model deployment name in your Foundry project
# If not specified, will default to gpt-4o-mini
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Optional: Connection name for Foundry SDK
CONNECTION_NAME=oaiksk7hvjr6tbbk

# =============================================================================
# Azure OpenAI Direct Configuration (if using direct OpenAI endpoints)
# =============================================================================

# Azure OpenAI service endpoint (alternative to Foundry endpoint)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure OpenAI deployment name
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# =============================================================================
# Azure Authentication (Optional - DefaultAzureCredential handles most cases)
# =============================================================================

# Azure Subscription ID (optional, for resource management)
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure Tenant ID (optional, usually not needed)
AZURE_TENANT_ID=your-tenant-id

# Azure Client ID for service principal authentication (optional)
AZURE_CLIENT_ID=your-client-id

# Azure Client Secret for service principal authentication (optional)
AZURE_CLIENT_SECRET=your-client-secret

# =============================================================================
# Additional Configuration
# =============================================================================

# Environment designation
ENVIRONMENT=development

# Project name for tracking
PROJECT_NAME=ai-labs-foundry-sdk

# Logging level
LOG_LEVEL=INFO