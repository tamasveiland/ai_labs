# =============================================================================
# Lab06: Speech Conversation — Environment Configuration
# =============================================================================
# These values are automatically populated after running: azd provision
# To export them to a .env file:  azd env get-values > .env
# =============================================================================

# Azure Speech Service (required)
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=eastus2
AZURE_SPEECH_ENDPOINT=https://your-speech-service.cognitiveservices.azure.com/

# Azure OpenAI (required)
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional — for Entra ID token auth with Speech (instead of key)
# AZURE_SPEECH_RESOURCE_ID=/subscriptions/xxx/resourceGroups/xxx/providers/Microsoft.CognitiveServices/accounts/xxx

# Optional — speech customisation
# SPEECH_VOICE=en-US-JennyNeural
# SPEECH_LANGUAGE=en-US